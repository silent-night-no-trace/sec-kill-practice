{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for seckill metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 5}, {"color": "red", "value": 20}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "seckill_async_requests{application=\"$application\",env=~\"$env\",status=\"pending\"}",
          "instant": true,
          "legendFormat": "pending",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Pending Async Requests",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(seckill_order_persist_total{application=\"$application\",env=~\"$env\",result=\"success\"}[5m]))",
          "instant": true,
          "legendFormat": "success",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Successful Orders (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 10}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(seckill_async_enqueue_total{application=\"$application\",env=~\"$env\",result=\"publish_failed\"}[5m]))",
          "instant": true,
          "legendFormat": "publish_failed",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Async Publish Failures (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(seckill_protection_reject_total{application=\"$application\",env=~\"$env\",action=\"purchase\",reason=\"rate_limit_exceeded\"}[5m]))",
          "instant": true,
          "legendFormat": "rate_limited",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Purchase Rate Limit Rejects (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (result) (increase(seckill_order_persist_total{application=\"$application\",env=~\"$env\"}[5m]))",
          "legendFormat": "{{result}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Order Persist Results (5m Increase)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (result) (increase(seckill_async_enqueue_total{application=\"$application\",env=~\"$env\"}[5m]))",
          "legendFormat": "{{result}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Async Enqueue Results (5m Increase)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, uri, method) (rate(http_server_requests_seconds_bucket{application=\"$application\",env=~\"$env\",uri!~\"/actuator.*\"}[5m])))",
          "legendFormat": "P95 {{method}} {{uri}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le, uri, method) (rate(http_server_requests_seconds_bucket{application=\"$application\",env=~\"$env\",uri!~\"/actuator.*\"}[5m])))",
          "legendFormat": "P99 {{method}} {{uri}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "HTTP P95 / P99 Latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (reason) (increase(seckill_protection_reject_total{application=\"$application\",env=~\"$env\",action=\"purchase\"}[5m]))",
          "legendFormat": "{{reason}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Protection Reject Reasons (Purchase)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["seckill", "prometheus", "overview"],
  "templating": {
    "list": [
      {
        "current": {"selected": true, "text": "seckill", "value": "seckill"},
        "hide": 0,
        "includeAll": false,
        "label": "application",
        "multi": false,
        "name": "application",
        "options": [],
        "query": "label_values(seckill_order_persist_total, application)",
        "refresh": 2,
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      },
      {
        "current": {"selected": true, "text": "All", "value": ".*"},
        "hide": 0,
        "includeAll": true,
        "label": "env",
        "multi": false,
        "name": "env",
        "options": [],
        "query": "label_values(seckill_order_persist_total{application=\"$application\"}, env)",
        "refresh": 2,
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Seckill Overview",
  "uid": "seckill-overview",
  "version": 2,
  "weekStart": ""
}
